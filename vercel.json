{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/telegram", "destination": "/api/telegram.js" },
    { "source": "/api/retry-cron", "destination": "/api/retry-cron.js" },
    { "source": "/api/dashboard", "destination": "/api/dashboard.js" },
    { "source": "/api/test", "destination": "/api/test.js" },
    { "source": "/api/health", "destination": "/api/health.js" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
